# ---- LLM endpoint (your GPT-5.4) ----
# OpenAI-compatible /v1/chat/completions assumed. Adjust server/llm.py if yours differs.
LLM_BASE_URL=https://your-gpt54-endpoint
LLM_TOKEN=your-temp-token
LLM_MODEL=gpt-5.4

# ---- AppDynamics (optional) ----
# If set, the server can pull a crash stacktrace by crash id instead of pasting.
# NOTE: uses the controller restui endpoints, which are not an officially stable
# public API. Confirm the paths against YOUR controller version before relying on it.
APPD_CONTROLLER_URL=
APPD_ACCESS_TOKEN=
APPD_APP_ID=

# ---- Git host (for PR link + owners) ----
# GitHub assumed. For GitLab/Bitbucket, adjust server/gitlink.py.
GITHUB_TOKEN=
GITHUB_OWNER=your-org
GITHUB_REPO=your-mobile-repo
# Local clone of the repo, used for git blame. Must be checked out to the build's commit/tag.
REPO_PATH=/path/to/local/clone

# ---- Symbolication tools (optional, must be installed locally) ----
# Android: R8 retrace. Point at the retrace jar, OR leave blank to try `retrace` on PATH.
R8_RETRACE_JAR=
# App package prefix used to pick the first "our code" frame from the stack.
APP_PACKAGE_PREFIX=com.bank

# ---- Jira (optional) ----
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@your-org.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=MOB

# ---- PR raising (uses GITHUB_* above) ----
GITHUB_BASE_BRANCH=main

# ---- Web search for solutions (optional) ----
# Google Programmable Search / Custom Search JSON API.
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=
